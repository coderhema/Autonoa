# Required
BNB_API_KEY=your_bnb_chain_api_key
TRUST_WALLET_API_KEY=your_trust_wallet_api_key
CMC_API_KEY=your_coinmarketcap_pro_api_key
PRIVATE_KEY=your_wallet_private_key

# Moltbook (optional — enables social layer)
MOLTBOOK_API_KEY=your_moltbook_api_key
MOLTBOOK_AGENT_NAME=Autonoa
MOLTBOOK_SUBMOLT=autonoa-trades

# Optional (defaults shown)
BNB_NETWORK=bsc-mainnet
MAX_DRAWDOWN=30
MAX_DAILY_TRADES=10
MAX_PER_TRADE=0.5
SLIPPAGE=0.5
MIN_VOLUME_24H=100000
